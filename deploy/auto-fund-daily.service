[Unit]
Description=Auto Fund Agent daily poll + digest
After=network-online.target

[Service]
Type=oneshot
WorkingDirectory=/opt/AUTO-FUND-AGENT
EnvironmentFile=/opt/AUTO-FUND-AGENT/.env
ExecStart=/bin/bash -c '/opt/AUTO-FUND-AGENT/.venv/bin/python -m src.jobs.poll && /opt/AUTO-FUND-AGENT/.venv/bin/python -m src.jobs.digest'
User=auto-fund

[Install]
WantedBy=multi-user.target
