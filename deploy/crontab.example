# Weekdays: poll RSS at 14:30 and 14:35, then send digest at 14:40
30 14 * * 1-5 cd /opt/AUTO-FUND-AGENT && /opt/AUTO-FUND-AGENT/.venv/bin/python -m src.jobs.poll --limit 5 >> /var/log/auto-fund-poll.log 2>&1
35 14 * * 1-5 cd /opt/AUTO-FUND-AGENT && /opt/AUTO-FUND-AGENT/.venv/bin/python -m src.jobs.poll --limit 5 >> /var/log/auto-fund-poll.log 2>&1
40 14 * * 1-5 cd /opt/AUTO-FUND-AGENT && /opt/AUTO-FUND-AGENT/.venv/bin/python -m src.jobs.digest >> /var/log/auto-fund-digest.log 2>&1
