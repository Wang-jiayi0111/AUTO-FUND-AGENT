[Unit]
Description=Auto Fund Agent RSS Poll
After=network-online.target

[Service]
Type=oneshot
WorkingDirectory=/opt/AUTO-FUND-AGENT
EnvironmentFile=/opt/AUTO-FUND-AGENT/.env
ExecStartPre=/opt/AUTO-FUND-AGENT/.venv/bin/python -m src.tools.apply_manual_submissions
ExecStart=/opt/AUTO-FUND-AGENT/.venv/bin/python -m src.jobs.poll --limit 1 --refresh-rss
User=auto-fund

[Install]
WantedBy=multi-user.target
