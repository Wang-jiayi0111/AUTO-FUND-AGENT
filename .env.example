# WeChat public account RSS URLs (from WeWe RSS or any RSS provider)
# See docs/RSS_SETUP.md
RSS_LANJING=
RSS_TIANTIAN=
RSS_JIAZHI=
RSS_YAGE=

# Feishu Open API
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_APP_TOKEN=
FEISHU_TABLE_BLOGGERS=
FEISHU_TABLE_FOLLOW_LIST=
FEISHU_TABLE_FOCUS_LIST=
FEISHU_TABLE_OPERATIONS=
FEISHU_TABLE_ARTICLES=
FEISHU_TABLE_FUND_MAPPING=
FEISHU_TABLE_PENDING_REVIEW=

# WeCom group robot webhook
WECOM_WEBHOOK_URL=

# 阿里云百炼 / DashScope LLM（OpenAI 兼容接口）
# 任选其一：
#   1) 在此填写 LLM_API_KEY=sk-xxx
#   2) 使用系统环境变量（推荐）：LLM_API_KEY 或 DASHSCOPE_API_KEY
# 若已设系统变量，下面留空即可
LLM_API_KEY=
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus
LLM_VISION_MODEL=qwen-vl-plus
LLM_TIMEOUT_SECONDS=180
LLM_MAX_RETRIES=3

# Optional (documentation only; jobs use Task Scheduler / systemd timer, not this interval)
POLL_INTERVAL_MINUTES=30
DIGEST_HOUR=14
DIGEST_MINUTE=30
CONFIDENCE_AUTO_THRESHOLD=0.85
CONFIDENCE_REVIEW_THRESHOLD=0.60
FEISHU_BASE_URL=https://your-feishu-base-url
